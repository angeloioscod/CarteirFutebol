{
  "expo": {
    "name": "Carteira Futebol",
    "slug": "carteira-futebol-v1",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#090E09"
      },
      "package": "com.carteirafutebol.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.carteirafutebol.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para adicionar foto do atleta.",
          "cameraPermission": "O app precisa da câmera para tirar foto do atleta."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "94338463-c47b-4f59-a3f8-25080227a913"
      }
    }
  }
}
