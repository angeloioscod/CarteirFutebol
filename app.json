{
  "expo": {
    "name": "Carteira Futebol",
    "slug": "carteira-futebol",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#090E09"
      },
      "package": "com.carteirafutebol.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.carteirafutebol.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para adicionar foto do atleta.",
          "cameraPermission": "O app precisa da câmera para tirar foto do atleta."
        }
      ],
      "expo-font"
    ]
  }
}
